# Contemplay — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Chave da API Anthropic (obrigatório para OCR dos vídeos)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token com permissão "Contents: Read & Write"
# Gerar em: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=ghp_...

# Repositório no formato usuario/repo
GITHUB_REPO=nikollas/contemplay

# Branch de deploy (normalmente main)
GITHUB_BRANCH=main
